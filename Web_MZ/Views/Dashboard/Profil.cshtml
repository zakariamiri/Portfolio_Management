@{
    Layout = null;
}
@using Web_MZ.Entities
@model ProfilViewModel


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TalentFrame - Profile</title>

    <link rel="icon" type="image/png" href="~/images/logo2.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/StyleSheet5.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

</head>

<body class="fontt">
    <!-- NAVBAR SUPERIEURE -->
    <nav class="navbar navbar-expand-lg bg-white py-2 sticky-top" style="border-bottom: 0.5px solid #ddd;z-index: 1020;">
        <div class="container-fluid d-flex justify-content-between align-items-center">

            <!-- LEFT SIDE (Logo) -->
            <a class="navbar-brand" href="#">
                <img src="~/images/logo.png" alt="TalentFrame Logo" width="150">
            </a>

            <!-- RIGHT SIDE -->
            <div class="d-flex align-items-center gap-4">

                <!-- Search bar -->
                <form class="d-none d-md-flex">
                    <div class="search-wrapper">
                        <i class="ri-search-line search-icon"></i>
                        <input class="form-control search-input" type="search" placeholder="Search…">
                    </div>
                </form>

                <!-- Notification icon -->
                <i class="ri-notification-3-line fs-4 notification-icon"></i>

                <!-- Profile -->
                <div class="d-flex align-items-center gap-2 profile-box">
                    <div class="profile-pic" style="background-image: url('@Url.Content(@Model.Creator.ProfileImage)');"></div>

                    <div>
                        <div class="fw-bold capitalize-first">@ViewBag.FirstName @ViewBag.LastName</div>
                        <div class="small text-muted capitalize-first">@Model.Creator.Bio</div>
                    </div>
                </div>

            </div>
        </div>
    </nav>


    <!-- NAVBAR INFERIEURE (LIENS CENTRES ET EGALITAIRES) -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm py-3 sticky-top" style="z-index: 1010;top: 56px;">
        <div class="container-fluid">

            <!-- LEFT LINKS -->
            <div class="d-flex">
                <a href="@Url.Action("Dash", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-home-4-line me-1"></i> Home
                </a>
                <a href="@Url.Action("Projet", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-stack-line me-1"></i> Add Project <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("Experience", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-briefcase-line me-1"></i> Add Experience <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("Certif", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-award-fill me-1"></i> Add Certification <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("competence", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-git-branch-fill me-1"></i>Add Skill <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("Message", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-mail-send-fill me-1"></i> Messages <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
            </div>

            <div class="dropdown ms-auto">
                <a class="btn settings-btn dropdown-toggle" href="#" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ri-settings-3-line me-1"></i> Settings
                </a>
                <ul class="dropdown-menu dropdown-menu-end settings-menu">
                    <li><a class="dropdown-item" href="@Url.Action("Profil", "Dashboard")"><i class="ri-user-line me-2"></i> Profile</a></li>
                    <li><a class="dropdown-item" href="#"><i class="ri-lock-line me-2"></i> Security</a></li>

                    <li><hr class="dropdown-divider"></li>

                    <li>
                        <a class="dropdown-item text-danger" href="@Url.Action("Index", "Home")">
                            <i class="ri-logout-circle-line me-2"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>


    <div class="container mt-4">

        <div class="card shadow-lg">
            <div class="card-body">
                <div class="row g-4 align-items-center">

                    <!-- Image -->
                    <div class="col-auto ms-3">
                        <div class="rounded-circle overflow-hidden" style="width:180px; height:180px;">
                            <img src="@Url.Content(Model.Creator.ProfileImage ?? "~/images/profile-none.png")"
                                 class="img-fluid"
                                 style="width:100%; height:100%; object-fit:cover;">
                        </div>
                    </div>

                    <!-- Infos -->
                    <div class="col">
                        <h3 class="fw-bold mb-2 capitalize-first">
                            @ViewBag.FirstName @ViewBag.LastName
                        </h3>

                        <p class="text-muted mb-2 capitalize-first">
                            @Model.Creator.Bio
                        </p>

                        <p class="text-success mb-2 capitalize-first">
                            <i class="ri-map-pin-line me-1 text-success"></i>@ViewBag.Country
                        </p>

                        <!-- Réseaux sociaux -->
                        <div class="d-flex gap-4">
                            <!-- GitHub -->
                            <a href="@Model.Creator.GitHub" target="_blank"
                               class="text-decoration-none text-dark fw-semibold">
                                <i class="ri-github-fill me-1"></i> GitHub
                            </a>

                            <!-- LinkedIn -->
                            <a href="@Model.Creator.LinkedIn" target="_blank"
                               class="text-decoration-none text-primary fw-semibold">
                                <i class="ri-linkedin-box-fill me-1"></i> LinkedIn
                            </a>
                        </div>
                    </div>

                </div>
            </div>

            <div class="card-footer bg-white text-end d-flex justify-content-end gap-2">
                <a href="@Url.Action("DownloadCv", "Dashboard", new { creatorId = Model.Creator.Id })"
                   class="btn btn-success btn-sm py-2">
                    <i class="ri-download-2-line me-1"></i> Download CV
                </a>


                <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                    <i class="ri-edit-line me-1"></i> Edit Profile
                </button>
            </div>
        </div>


        <!-- Modal Edit Profile -->
        <div class="modal fade" id="editProfileModal" tabindex="-1" aria-labelledby="editProfileModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title" id="editProfileModalLabel">Edit Profile</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <form asp-action="EditProfile" method="post" enctype="multipart/form-data">

                            <input type="hidden" asp-for="Creator.Id" />


                            <div class="mb-3">
                                <label class="form-label">Profile Image</label>

                                <div class="d-flex align-items-center gap-3">

                                    <!-- Preview -->
                                    <img id="imagePreview"
                                         src="@Url.Content(Model.Creator.ProfileImage ?? "~/images/profile-none.png")"
                                         class="rounded-circle border"
                                         style="width:120px; height:120px; object-fit:cover;">

                                    <!-- File input -->
                                    <div class="flex-grow-1">
                                        <input type="file"
                                               class="form-control"
                                               name="ProfileImageFile"
                                               accept="image/*"
                                               onchange="previewImage(event)">
                                        <small class="text-muted">
                                            JPG, PNG – max 2MB
                                        </small>
                                    </div>

                                </div>
                            </div>

                            <div class="mb-3">
                                <label>Bio</label>
                                <textarea class="form-control" asp-for="Creator.Bio"></textarea>
                            </div>

                            <div class="mb-3">
                                <label>LinkedIn</label>
                                <input class="form-control" asp-for="Creator.LinkedIn" />
                            </div>

                            <div class="mb-3">
                                <label>GitHub</label>
                                <input class="form-control" asp-for="Creator.GitHub" />
                            </div>

                         

                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-success"><i class="ri-save-line me-1"></i>Save Changes</button>
                            </div>

                        </form>

                    </div>

                </div>
            </div>
        </div>

        <script>
            function previewImage(event) {
                const reader = new FileReader();
                reader.onload = function () {
                    document.getElementById('imagePreview').src = reader.result;
                };
                reader.readAsDataURL(event.target.files[0]);
            }
        </script>

       


        <!-- ACCOUNT INFO -->

        <div class="card shadow-lg mt-4 mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/informations-personnelles.png" alt="Profile" width="32" height="32" class="me-2">
                Account Information
            </div>


            <div class="card-body" style="font-size: 17px;">
                <div class="row g-3">

                    <!-- First Name -->
                    <div class="col-md-6">
                        <small class="text-muted">First Name</small>
                        <div class="fw-semibold capitalize-first">@ViewBag.FirstName</div>
                    </div>

                    <!-- Last Name -->
                    <div class="col-md-6">
                        <small class="text-muted">Last Name</small>
                        <div class="fw-semibold capitalize-first">@ViewBag.LastName</div>
                    </div>

                    <!-- Phone -->
                    <div class="col-md-6">
                        <small class="text-muted">Phone</small>
                        <div class="fw-semibold">
                            <i class="ri-phone-line me-1"></i> +212 @ViewBag.Phone
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6">
                        <small class="text-muted">Email</small>
                        <div class="fw-semibold">
                            <i class="ri-mail-add-line me-1"></i> @ViewBag.Email
                        </div>
                    </div>


                    <!-- Account Creation Date -->
                    <div class="col-md-12">
                        <small class="text-muted">Account Created At</small>
                        <div class="fw-semibold">
                            <i class="ri-calendar-line me-1"></i> @ViewBag.Date
                        </div>
                    </div>

                </div>
            </div>

            <div class="card-footer bg-white text-end d-flex justify-content-end gap-2">
                    <button class="btn btn-outline-primary btn-sm py-2"
                            data-bs-toggle="modal"
                            data-bs-target="#editAccountModal">
                        <i class="ri-edit-line me-1"></i> Edit Account
                    </button>
            </div>



        </div>

        <!-- Modal Edit Account -->
        <div class="modal fade" id="editAccountModal" tabindex="-1"
             aria-labelledby="editAccountModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title fw-bold" id="editAccountModalLabel">
                            Edit Account Information
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>

                    <form asp-action="EditAccount" method="post">

                        <div class="modal-body">

                            <!-- First Name -->
                            <div class="mb-3">
                                <label class="form-label">First Name</label>
                                <input type="text"
                                       class="form-control"
                                       name="FirstName"
                                       value="@ViewBag.FirstName"
                                       required>
                            </div>

                            <!-- Last Name -->
                            <div class="mb-3">
                                <label class="form-label">Last Name</label>
                                <input type="text"
                                       class="form-control"
                                       name="LastName"
                                       value="@ViewBag.LastName"
                                       required>
                            </div>
                            <!-- Email -->
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email"
                                       class="form-control"
                                       name="Email"
                                       value="@ViewBag.Email"
                                       required>
                            </div>

                            <!-- Phone -->
                            <div class="mb-3">
                                <label class="form-label">Phone</label>
                                <input type="text"
                                       class="form-control"
                                       name="Phone"
                                       value="@ViewBag.Phone">
                            </div>

                            <!-- Country -->
                            <div class="mb-3">
                                <label class="form-label">Country</label>
                                <select class="form-select" name="Country">
                                    <option value="Morocco" selected="@((string)ViewBag.Country == "Morocco")">Morocco</option>
                                    <option value="France" selected="@((string)ViewBag.Country == "France")">France</option>
                                    <option value="Canada" selected="@((string)ViewBag.Country == "Canada")">Canada</option>
                                    <option value="Germany" selected="@((string)ViewBag.Country == "Germany")">Germany</option>
                                </select>
                            </div>

                        </div>

                        <div class="modal-footer">
                            <button type="button"
                                    class="btn btn-secondary"
                                    data-bs-dismiss="modal">
                                Cancel
                            </button>

                            <button type="submit"
                                    class="btn btn-success">
                                <i class="ri-save-line me-1"></i> Save Changes
                            </button>

                        </div>

                    </form>

                </div>
            </div>
        </div>



        <!-- Experience -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/mallette.png" width="24" class="me-2" /> Experience
            </div>

            <div class="card-body">
                @foreach (var exp in Model.Experiences)
                {
                    <div class="mb-3">
                        <h6 class="fw-semibold mb-1">@exp.Title</h6>
                        <p class="text-muted mb-1">@exp.Company · @exp.Location</p>
                        <small class="text-secondary">
                            <i class="ri-calendar-line me-1"></i>
                            @exp.StartDate.ToString("yyyy") -
                            @(exp.EndDate != null ? exp.EndDate.Value.ToString("yyyy") : "Present")
                        </small>
                    </div>
                }

            </div>
        </div>

        <!-- Projects -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/nouveau-projet.png" width="24" class="me-2" /> Projects
            </div>

            <div class="card-body">
                @foreach (var p in Model.Projects)
                {
                    <div class="mb-3">
                        <h6 class="fw-semibold mb-1">@p.Title</h6>
                        <p class="text-muted mb-1">@p.Description</p>

                        @if (!string.IsNullOrEmpty(p.Link))
                        {
                            <a href="@p.Link" target="_blank" class="text-primary text-decoration-none">
                                View Project <i class="ri-arrow-right-line"></i>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>



        <!-- Certifications -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/medaille.png" width="24" class="me-2" /> Certifications
            </div>

            <div class="card-body">
                @foreach (var c in Model.Certifications)
                {
                    <div class="mb-2">
                        <h6 class="fw-semibold mb-0">@c.Title</h6>
                        <small class="text-secondary">
                            <i class="ri-calendar-check-line me-1"></i>
                            @c.DateIssued.ToString("yyyy")
                        </small>
                    </div>
                }
            </div>
        </div>



        <!-- Skills -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/competences.png" width="32" class="me-2" /> Skills
            </div>

            <div class="card-body">
                @foreach (var s in Model.Competences)
                {
                    var percent = s.Level * 20;
                    var colorClass = s.Level switch
                    {
                        1 => "bg-danger",
                        2 => "bg-warning",
                        3 => "bg-info",
                        4 => "bg-success",
                        5 => "bg-primary",
                        _ => "bg-secondary"
                    };
                    var levelText = s.Level switch
                    {
                        1 => "Beginner",
                        2 => "Junior",
                        3 => "Intermediate",
                        4 => "Advanced",
                        5 => "Expert",
                        _ => ""
                    };

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span class="fw-semibold">@s.Name</span>
                            <span class="text-muted">(@levelText)</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated @colorClass"
                                 role="progressbar"
                                 style="width:@percent%">
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>



        <!-- langue -->

        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/linternet.png" width="24" class="me-2"> Languages
            </div>

            <div class="card-body">
                @if (Model.Langues != null && Model.Langues.Count > 0)
                {
                    foreach (var langue in Model.Langues)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>@langue.Nom</span>
                            <span class="text-muted">@langue.Niveau</span>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted text-center">
                        No languages added
                    </div>
                }
            </div>
        </div>



    </div>

   



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
