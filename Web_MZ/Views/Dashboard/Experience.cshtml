@{
    Layout = null;
}
@using Web_MZ.Entities
@model List<Experience>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TalentFrame - Experience</title>

    <link rel="icon" type="image/png" href="~/images/logo2.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/StyleSheet5.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        /* Bouton Cancel */
        .btn-cancel {
            background-color: #35af16;
            border-color: #35af16;
            color: white;
        }

            .btn-cancel:hover {
                background-color: #2f9c13;
                border-color: #2f9c13;
            }

        /* Bouton Save */
        .btn-save {
            background-color: #0a3f70;
            border-color: #0a3f70;
            color: white;
        }

            .btn-save:hover {
                background-color: #06325c;
                border-color: #06325c;
            }
    </style>
</head>

<body class="fontt">
    <!-- NAVBAR SUPERIEURE -->
    <nav class="navbar navbar-expand-lg bg-white py-2" style="border-bottom: 0.5px solid #ddd;">
        <div class="container-fluid d-flex justify-content-between align-items-center">

            <!-- LEFT SIDE (Logo) -->
            <a class="navbar-brand" href="#">
                <img src="~/images/logo.png" alt="TalentFrame Logo" width="150">
            </a>

            <!-- RIGHT SIDE -->
            <div class="d-flex align-items-center gap-4">

                <!-- Search bar -->
                <form class="d-none d-md-flex">
                    <div class="search-wrapper">
                        <i class="ri-search-line search-icon"></i>
                        <input class="form-control search-input" type="search" placeholder="Search…">
                    </div>
                </form>

                <!-- Notification icon -->
                <i class="ri-notification-3-line fs-4 notification-icon"></i>

                <!-- Profile -->
                <div class="d-flex align-items-center gap-2 profile-box">
                    <div class="profile-pic" style="background-image: url('@Url.Content(ViewBag.ProfileImage)');"></div>

                    <div>
                        <div class="fw-bold capitalize-first">@ViewBag.FirstName @ViewBag.LastName</div>
                        <div class="small text-muted capitalize-first">@ViewBag.Bio</div>
                    </div>
                </div>

            </div>
        </div>
    </nav>


    <!-- NAVBAR INFERIEURE (LIENS CENTRES ET EGALITAIRES) -->
    <nav class="navbar navbar-expand-lg shadow-sm py-3">
        <div class="container-fluid">

            <!-- LEFT LINKS -->
            <div class="d-flex">
                <a href="@Url.Action("Dash", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-home-4-line me-1"></i> Home
                </a>
                <a href="@Url.Action("Projet", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-stack-line me-1"></i> Add Project <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("Experience", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-success fs-6 px-3 py-2">
                    <i class="ri-briefcase-line me-1"></i> Add Experience <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("Certif", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-award-fill me-1"></i> Add Certification <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("competence", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-git-branch-fill me-1"></i>Add Skill <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
                <a href="@Url.Action("Message", "Dashboard")" class="nav-link-custom text-decoration-none d-flex align-items-center text-dark fs-6 px-3 py-2">
                    <i class="ri-mail-send-fill me-1"></i> Messages <i class="ri-arrow-down-s-line ms-2"></i>
                </a>
            </div>

            <div class="dropdown ms-auto">
                <a class="btn settings-btn dropdown-toggle" href="#" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ri-settings-3-line me-1"></i> Settings
                </a>
                <ul class="dropdown-menu dropdown-menu-end settings-menu">
                    <li><a class="dropdown-item" href="@Url.Action("Profil", "Dashboard")"><i class="ri-user-line me-2"></i> Profile</a></li>
                    <li><a class="dropdown-item" href="#"><i class="ri-lock-line me-2"></i> Security</a></li>

                    <li><hr class="dropdown-divider"></li>

                    <li>
                        <a class="dropdown-item text-danger" href="@Url.Action("Index", "Home")">
                            <i class="ri-logout-circle-line me-2"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>


    <div class="container mt-4">

        <!-- Bouton pour afficher le formulaire d'ajout -->
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-primary btn-sm"
                    data-bs-toggle="collapse"
                    data-bs-target="#addExperienceForm">
                <i class="ri-add-line me-1"></i> Add Experience
            </button>
        </div>

        <!-- Formulaire d'ajout -->
        <div class="collapse" id="addExperienceForm">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form asp-action="AddExperience" method="post">
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label">Title</label>
                                <input type="text" class="form-control" name="Title" placeholder="Title" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Company</label>
                                <input type="text" class="form-control" name="Company" placeholder="Company" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Location</label>
                                <input type="text" class="form-control" name="Location" placeholder="Location" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Start Date</label>
                                <input type="date" class="form-control" name="StartDate" placeholder="StartDate" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">End Date</label>
                                <input type="date" class="form-control" name="EndDate" placeholder="EndDate" />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" name="Description" placeholder="Description"></textarea>
                            </div>

                        </div>

                        <button type="submit" class="btn btn-primary btn-sm mt-3">
                            <i class="ri-add-line"></i> Add Experience
                        </button>
                    </form>
                </div>
            </div>
        </div>


        <!-- Modal pour modifier une projet -->
        <div class="modal fade" id="editExperienceModal">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form asp-action="EditExperience" method="post">
                        <div class="modal-header">
                            <h5 class="modal-title">Edit Experience</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        

                        <div class="modal-body">
                            <input type="hidden" name="Id" id="editId" />

                            <div class="mb-2">
                            <label class="form-label">Title</label>
                            <input class="form-control" name="Title" id="editTitle" />
                            </div>

                            <div class="mb-2">
                            <label class="form-label">Company</label>
                            <input class="form-control" name="Company" id="editCompany" />
                            </div>

                            <div class="mb-2">
                            <label class="form-label">Location</label>
                            <input class="form-control" name="Location" id="editLocation" />
                            </div>

                            <div class="mb-2">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="Description" id="editDesc"></textarea>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label class="form-label">Start</label>
                                    <input type="date"
                                           class="form-control"
                                           name="StartDate"
                                           id="editStart" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">End</label>
                                    <input type="date"
                                           class="form-control"
                                           name="EndDate"
                                           id="editEnd" />
                                </div>
                            </div>


                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary btn-cancel" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit"  class="btn btn-success btn-save">Save changes</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>


        <!-- Liste des Certifications -->

        <div class="card shadow-sm">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <i class="ri-briefcase-line me-2"></i> My Experiences

            </div>

            <div class="card-body p-0">
                <table class="table table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Company</th>
                            <th>Location</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var exp in Model)
                        {
                            <tr>
                                <td>@exp.Title</td>
                                <td>@exp.Company</td>
                                <td>@exp.Location</td>
                                <td>@exp.StartDate.ToShortDateString()</td>
                                <td>@(exp.EndDate.HasValue? exp.EndDate.Value.ToShortDateString() : "Present")</td>


                                <td>
                                    <!-- EDIT -->
                                    <button class="btn btn-sm btn-outline-secondary me-1"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editExperienceModal"
                                            data-id="@exp.Id"
                                            data-title="@exp.Title"
                                            data-company="@exp.Company"
                                            data-location="@exp.Location"
                                            data-desc="@exp.Description"
                                            data-start="@exp.StartDate.ToString("yyyy-MM-dd")"
                                            data-end="@exp.EndDate?.ToString("yyyy-MM-dd")">
                                        <i class="ri-edit-line"></i>
                                    </button>

                                    <!-- DELETE -->
                                    <form asp-action="DeleteExperience" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@exp.Id" />
                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Delete this experience?')">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>

    </div>

    <script>
        document.getElementById('editExperienceModal')
        .addEventListener('show.bs.modal', function (e) {

            var b = e.relatedTarget;

            editId.value = b.dataset.id;
            editTitle.value = b.dataset.title;
            editCompany.value = b.dataset.company;
            editLocation.value = b.dataset.location;
            editDesc.value = b.dataset.desc;
            editStart.value = b.dataset.start;
            editEnd.value = b.dataset.end;
        });
    </script>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>


</html>

