@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TalentFrame - SignUp</title>

    <link rel="icon" type="image/png" href="~/images/logo2.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
   


    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

</head>

<body class="fontt">

    <div class="p-3">
        <img src="~/images/logo.png" alt="TalentFrame Logo" width="200">
    </div>

    <div class="container mt-4">

        <div class="d-flex justify-content-center mb-5">
            <img src="~/images/logo2.png" alt="TalentFrame Logo" width="50">
        </div>
        <!-- Title -->
        <h2 class="fw-semibold mb-4 text-center">
            Join us as a portfolio creator or recruiter
        </h2>

        <form>
            <div class="row justify-content-center">

                <!-- Card 1 -->
                <div class="col-md-5 mb-4">
                    <label class="w-100">
                        <div class="card p-3 role-card">
                            <div class="d-flex align-items-start">
                                <input type="radio" name="role" value="recruiter" class="role-radio mt-1">
                                <div>
                                    <i class="ri-user-search-line"></i>
                                    <h5 class="fw-semibold">I explore portfolios to find talent</h5>
                                    <p class="text-muted mb-0">Browse profiles and discover the best creators.</p>
                                </div>
                            </div>
                        </div>
                    </label>
                </div>

                <!-- Card 2 -->
                <div class="col-md-5 mb-4">
                    <label class="w-100">
                        <div class="card p-3 role-card">
                            <div class="d-flex align-items-start">
                                <input type="radio" name="role" value="creator" class="role-radio mt-1">
                                <div>
                                    <i class="ri-user-add-line"></i>
                                    <h5 class="fw-semibold">I create a portfolio to present my work</h5>
                                    <p class="text-muted mb-0">Showcase your skills and get noticed by recruiters.</p>
                                </div>
                            </div>
                        </div>
                    </label>
                </div>

            </div>

            <!-- Create account button -->
            <div class="create-account-container">
                <button class="create-account-btn btn btn-primary" type="button"
                        data-recruiter-url='@Url.Action("recruiter", "SignupRecruiter")'
                        data-creator-url='@Url.Action("Creator", "SignupCreator")'>
                    Create Account
                </button>

            </div>

            <div class="text-center mt-3">
                <small class="text-muted">
                    Already have an account?
                    <a class="text-primary text-decoration-underline fw-semibold ms-1"
                       href='@Url.Action("Login", "Login")'>
                        Login
                    </a>

                </small>
            </div>
        </form>
    </div>

    <script src="/js/site.js"></script>
   


</body>
</html>
