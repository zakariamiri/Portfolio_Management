@model ConsulterPortfolioVM

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TalentFrame</title>

    <link rel="icon" type="image/png" href="~/images/logo2.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/StyleSheet5.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
</head>

<body class="fontt">

    <!-- ================= NAVBAR (RECRUITER) ================= -->
    <nav class="navbar navbar-expand-lg bg-white py-2 sticky-top" style="border-bottom: 0.5px solid #ddd; z-index:1020;">
        <div class="container-fluid d-flex justify-content-between align-items-center">

            <a class="navbar-brand" href="#">
                <img src="~/images/logo.png" width="150">
            </a>

            <div class="d-flex align-items-center gap-4">

                <i class="ri-notification-3-line fs-4"></i>

                <div class="d-flex align-items-center gap-3 profile-box">
                    <div class="profile-pic"
                         style="background-image:url('@Url.Content(ViewBag.ProfileImage)')"></div>

                    <div>
                        <div class="fw-bold capitalize-first">
                            @ViewBag.FirstName @ViewBag.LastName
                        </div>
                        <div class="small text-muted capitalize-first">
                            @ViewBag.Position
                        </div>
                        <div class="small text-muted d-flex align-items-center gap-2">
                            <i class="ri-building-line text-primary"></i>
                            @ViewBag.CompanyName
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </nav>

    <!-- ================= CONTENT ================= -->
    <div class="container mt-4">

        <!-- ===== CREATOR HEADER ===== -->
        <div class="card shadow-lg mb-4">
            <div class="card-body">
                <div class="row align-items-center g-4">

                    <div class="col-auto">
                        <div class="rounded-circle overflow-hidden" style="width:180px;height:180px;">
                            <img src="@Url.Content(
                                                             string.IsNullOrEmpty(Model.Creator.ProfileImage)
                                                             ? "~/images/profile-none.png"
                                                             : Model.Creator.ProfileImage)"
                                 class="img-fluid"
                                 style="width:100%;height:100%;object-fit:cover;">
                        </div>
                    </div>

                    <div class="col">
                        <h3 class="fw-bold capitalize-first">
                            @Model.Creator.User.FirstName @Model.Creator.User.LastName
                        </h3>

                        <p class="text-muted capitalize-first">
                            @Model.Creator.Bio
                        </p>

                        <p class="text-success capitalize-first">
                            <i class="ri-map-pin-line me-1"></i>
                            @Model.Creator.User.Country
                        </p>

                        <div class="d-flex gap-4">
                            @if (!string.IsNullOrEmpty(Model.Creator.GitHub))
                            {
                                <a href="@Model.Creator.GitHub" target="_blank" class="text-dark">
                                    <i class="ri-github-fill"></i> GitHub
                                </a>
                            }

                            @if (!string.IsNullOrEmpty(Model.Creator.LinkedIn))
                            {
                                <a href="@Model.Creator.LinkedIn" target="_blank" class="text-primary">
                                    <i class="ri-linkedin-box-fill"></i> LinkedIn
                                </a>
                            }
                        </div>
                    </div>

                </div>
            </div>
            <div class="card-footer bg-white text-end d-flex justify-content-end gap-2">
                <!-- Download CV -->
                <a href="@Url.Action("DownloadCV", "DashboardRecruiter", new { id = Model.Creator.Id })"
                   class="btn btn-success btn-sm px-3 py-2">
                    <i class="ri-download-2-line me-1"></i> Download CV
                </a>

                <!-- Contact -->
                <button type="button" class="btn btn-warning btn-sm px-3 py-2" data-bs-toggle="modal" data-bs-target="#contactModal">
                    <i class="ri-mail-send-fill me-1"></i> Contact
                </button>
            </div>
        </div>


        <!-- Modal Contact -->
        <div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title capitalize-first" id="contactModalLabel">Contact @Model.Creator.User.FirstName @Model.Creator.User.LastName</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <form asp-action="SendContact" method="post">
                        <div class="modal-body">
                            <input type="hidden" name="CreatorId" value="@Model.Creator.Id" />
                            <div class="mb-3">
                                <label for="Message" class="form-label">Message</label>
                                <textarea class="form-control" id="Message" name="Message" rows="4" placeholder="Write your message here..." required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-success" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Send</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Message de succès après envoi -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- ===== ACCOUNT INFO ===== -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/informations-personnelles.png" alt="Profile" width="32" height="32" class="me-2">

                Account Information
            </div>

            <div class="card-body" style="font-size: 17px;">
                <div class="row g-3">
                    <div class="col-md-6">
                        <small class="text-muted">First Name</small>
                        <div class="fw-semibold capitalize-first">@Model.Creator.User.FirstName</div>
                    </div>

                    <div class="col-md-6">
                        <small class="text-muted">Last Name</small>
                        <div class="fw-semibold capitalize-first">@Model.Creator.User.LastName</div>
                    </div>

                    <div class="col-md-6">
                        <small class="text-muted">Phone</small>
                        <div class="fw-semibold">
                            <i class="ri-phone-line me-1"></i>+212 @Model.Creator.User.Phone
                        </div>
                    </div>

                    <div class="col-md-6">
                        <small class="text-muted">Email</small>
                        <div class="fw-semibold">
                            <i class="ri-mail-add-line me-1"></i>@Model.Creator.User.Email
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== EXPERIENCE ===== -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/mallette.png" width="24" class="me-2" />Experience
            </div>
            <div class="card-body">
                @foreach (var exp in Model.Experiences)
                {
                    <div class="mb-3">
                        <h6 class="fw-semibold mb-1">@exp.Title</h6>
                        <p class="text-muted mb-1">@exp.Company · @exp.Location</p>
                        <small class="text-secondary">
                            <i class="ri-calendar-line me-1"></i>
                            @exp.StartDate.Year -
                            @(exp.EndDate?.Year.ToString() ?? "Present")
                        </small>
                    </div>
                }
            </div>
        </div>

        <!-- ===== PROJECTS ===== -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/nouveau-projet.png" width="24" class="me-2" />Projects
            </div>
            <div class="card-body">
                @foreach (var p in Model.Projects)
                {
                    <div class="mb-3">
                        <h6 class="fw-semibold mb-1">@p.Title</h6>
                        <p class="text-muted mb-1">@p.Description</p>

                        @if (!string.IsNullOrEmpty(p.Link))
                        {
                            <a href="@p.Link" target="_blank" class="text-primary text-decoration-none">
                                <i class="ri-arrow-right-line"></i>View Project
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- ===== SKILLS ===== -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/competences.png" width="32" class="me-2" /> Skills
            </div>
            <div class="card-body">
                @foreach (var s in Model.Competences)
                {
                    var percent = s.Level * 20;
                    var colorClass = s.Level switch
                    {
                        1 => "bg-danger",
                        2 => "bg-warning",
                        3 => "bg-info",
                        4 => "bg-success",
                        5 => "bg-primary",
                        _ => "bg-secondary"
                    };
                    var levelText = s.Level switch
                    {
                        1 => "Beginner",
                        2 => "Junior",
                        3 => "Intermediate",
                        4 => "Advanced",
                        5 => "Expert",
                        _ => ""
                    };
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span class="fw-semibold">@s.Name</span>
                            <span class="text-muted">(@levelText)</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated @colorClass"
                                 role="progressbar"
                                 style="width:@percent%;">
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>


        <!-- Certifications -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/medaille.png" width="24" class="me-2" /> Certifications
            </div>

            <div class="card-body">
                @foreach (var c in Model.Certifications)
                {
                    <div class="mb-2">
                        <h6 class="fw-semibold mb-0">@c.Title</h6>
                        <small class="text-secondary">
                            <i class="ri-calendar-check-line me-1"></i>
                            @c.DateIssued.ToString("yyyy")
                        </small>
                    </div>
                }
            </div>
        </div>

        <!-- ===== LANGUAGES ===== -->
        <div class="card shadow-lg mb-4">
            <div class="card-header bg-white fw-bold d-flex align-items-center">
                <img src="~/images/linternet.png" width="24" class="me-2">Languages
            </div>
            <div class="card-body">
                 @if (Model.Langues != null && Model.Langues.Count > 0)
                  {
                     foreach (var l in Model.Langues)
                     {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@l.Nom</span>
                                <span class="text-muted">@l.Niveau</span>
                            </div>
               
                     }
                }
                else
                {
                      <div class="text-muted text-center">
                               No languages added
                      </div>
                }
                </div>
            </div>

        </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

