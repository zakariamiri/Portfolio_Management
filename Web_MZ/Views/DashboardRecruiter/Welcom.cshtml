@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TalentFrame</title>

    <link rel="icon" type="image/png" href="~/images/logo2.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/StyleSheet5.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

</head>

<body class="fontt">
    <!-- NAVBAR SUPERIEURE -->
    <nav class="navbar navbar-expand-lg bg-white py-2 sticky-top" style="border-bottom: 0.5px solid #ddd;z-index: 1020;">
        <div class="container-fluid d-flex justify-content-between align-items-center">

            <!-- LEFT SIDE (Logo) -->
            <a class="navbar-brand" href="#">
                <img src="~/images/logo.png" alt="TalentFrame Logo" width="150">
            </a>

            <!-- RIGHT SIDE -->
            <div class="d-flex align-items-center gap-4">

                <!-- Search bar -->
                <form class="d-none d-md-flex">
                    <div class="search-wrapper">
                        <i class="ri-search-line search-icon"></i>
                        <input class="form-control search-input" type="search" placeholder="Search…">
                    </div>
                </form>

                <!-- Notification icon -->
                <i class="ri-notification-3-line fs-4 notification-icon"></i>

                <!-- Profile -->
                <div class="d-flex align-items-center gap-3 profile-box">
                    <div class="profile-pic" style="background-image: url('@Url.Content(ViewBag.ProfileImage)');"></div>

                    <div>
                        <div class="fw-bold capitalize-first">@ViewBag.FirstName @ViewBag.LastName</div>
                        <div class="small text-muted capitalize-first">@ViewBag.Position</div>
                        <!-- Company name with icon -->
                        <div class="small text-muted d-flex align-items-center gap-2">
                            <i class="ri-building-line text-primary capitalize-first"></i> @ViewBag.CompanyName
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </nav>




    <div class="container mt-4">
        <div class="row align-items-center">
            <!-- Ajouter la row -->
            <!-- Colonne texte -->
            <div class="col-md-6">
                <div class="mb-5" style="margin-top: 5rem;">
                    <h3 class="fw-semibold text-dark" style="font-size:45px;">
                        Welcome, @ViewBag.FirstName
                        <img src="~/images/au-revoir.png" alt="TalentFrame Logo" width="60" class="ms-1">
                        <span style="display:block; width:80px; height:3px; background:#28a745; border-radius:4px; margin-top:6px;"></span>
                    </h3>
                    <p class="text-muted">Here is an overview of the candidates you can review.</p>

                    <p class=" mt-4 mb-2" style="font-size:18px;">
                        You can click on each portfolio to see detailed information about the candidate's skills and experience.
                    </p>

                    <!-- Button with icon -->
                    <a href="@Url.Action("DashRecruiter", "DashboardRecruiter")" class="btn btn-success d-inline-flex align-items-center mt-4">
                        <i class="ri-eye-line me-2"></i>
                        View Portfolios
                    </a>
                </div>
            </div>

            <!-- Colonne animation -->
            <div class="col-md-6 text-center">
                <dotlottie-wc src="https://lottie.host/15a1274c-fb1c-4b1f-95be-2e53aa176404/9LyRerctzS.lottie"
                              style="width: 100%; max-width: 500px; height: auto;"
                              autoplay
                              loop
                speed="0.5"></dotlottie-wc>
            </div>

        </div>
    </div>



    <script src="https://unpkg.com/@@lottiefiles/dotlottie-wc@0.8.11/dist/dotlottie-wc.js" type="module"></script>   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>