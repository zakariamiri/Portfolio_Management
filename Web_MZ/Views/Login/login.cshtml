@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TalentFrame - Login</title>
    <link rel="icon" type="image/png" href="~/images/logo2.png" />
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


</head>

<body class="fontt">

    <!-- LOGO TOP LEFT -->
    <div class="p-3">
        <img src="~/images/logo.png" alt="TalentFrame Logo" width="200">
    </div>

    <!-- LOGIN CARD CENTERED -->
    <div class="d-flex justify-content-center align-items-center" style="min-height: 85vh;">
        <div class="card shadow login-card p-4">
            <div class="d-flex justify-content-center">
                <img src="~/images/logo2.png" alt="TalentFrame Logo" width="50">
            </div>
            <h4 class="text-center mb-4 mt-2 title-login fw-semibold">Login to TalentFrame</h4>

            <form method="post">
                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Email address</label>
                    <input name="email" type="email" class="form-control" placeholder="example@mail.com">
                </div>

                <!-- Password -->
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input name="password" type="password" class="form-control" placeholder="Enter your password">
                    <span id="passwordHelpInline" class="form-text">
                        Must be 8-20 characters long.
                    </span>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <!-- Continue Button -->
                <button type="submit" class="continue-btn mt-2">Continue</button>
            </form>

            <!-- Signup -->
            <div class="text-center mt-3">
                <small class="text-muted text-decoration-underline">Don’t have a TalentFrame account?</small>
            </div>
            <div class="d-flex justify-content-center">
                <button class="signup-link mt-2" type="button"
                        onclick='window.location.href="@Url.Action("choices", "Choices")"'>
                    Sign up
                </button>
            </div>

        </div>
    </div>

</body>
</html>

