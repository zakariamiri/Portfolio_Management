@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TalentFrame</title>
    <link rel="icon" type="image/png" href="~/images/logo2.png" />
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="fontt">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-white shadow">
        <div class="container-fluid">
            <!-- LOGO -->
            <a class="navbar-brand" href="#">
                <img src="~/images/logo.png" alt="Logo" width="200" class="d-inline-block align-text-top">
            </a>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <!-- Liens -->
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 mt-2">
                    <li class="nav-item me-3"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
                    <li class="nav-item me-3"><a class="nav-link" href="#">How it works</a></li>
                    <li class="nav-item me-3"><a class="nav-link" href="#">Contact us</a></li>
                </ul>
                <!-- Formulaire + Boutons -->
                <form class="d-flex align-items-center" role="search">
                    <button class="login-btn me-2" type="button"
                            onclick="window.location.href='@Url.Action("login", "Login")'">
                        Login
                    </button>
                    <button class="signup-btn me-2" type="button"
                            onclick="window.location.href='@Url.Action("choices", "Choices")'">
                        Signup
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <section>
        <div class="container">
            <div class="row align-items-center">
                <!-- 50% Paragraphe -->
                <div class="col-md-6">
                    <h2 class="titre-darkblue mb-4">Turn your talents into opportunities.</h2>
                    <p class="text-gray pb-4 par-titre pe-2 ">
                        With <strong>TalentFrame</strong>, create your portfolio in just a few clicks and connect your talents to the right opportunities. For both candidates and recruiters, everything becomes simple, fast, and efficient.
                    </p>
                    <button class="signup-btn2" type="button"
                            onclick="window.location.href='@Url.Action("choices", "Choices")'">
                        Start your journey
                    </button>
                </div>

                <!-- 50% Animation Lottie -->
                <div class="col-md-6 text-center">
                    <dotlottie-wc src="https://lottie.host/ad878712-44db-4e06-aef9-892e162571bd/ftHhXSWGW4.lottie"
                                  style="width: 600px; height: 500px;"
                                  autoplay
                                  loop>
                    </dotlottie-wc>
                </div>
            </div>
        </div>
    </section>
    <script src="https://unpkg.com/@@lottiefiles/dotlottie-wc@0.8.5/dist/dotlottie-wc.js" type="module"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>



